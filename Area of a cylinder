#include <math.h>

using namespace std;

class Cylinder{

public:
float radius;
float pi;
float height;

double calculate_area(){
    
    return (2*pi*pow(radius, 2.0)+2*pi*radius*height);
}

double calculate_volume(){
    
    return(pi*pow(radius, 2.0)*height);
}
};

